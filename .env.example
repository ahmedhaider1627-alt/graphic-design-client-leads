# Twitter API
TWITTER_API_KEY=your_api_key
TWITTER_API_SECRET=your_api_secret
TWITTER_BEARER_TOKEN=your_bearer_token

# Reddit API
REDDIT_CLIENT_ID=your_client_id
REDDIT_CLIENT_SECRET=your_client_secret
REDDIT_USER_AGENT=graphic-design-leads/1.0

# Google APIs
GOOGLE_API_KEY=your_google_api_key

# LinkedIn (optional - for profile scraping)
LINKEDIN_COOKIES=your_cookies_here

# Email & Contact Finding
HUNTER_API_KEY=your_hunter_api_key
ROCKETREACH_API_KEY=your_rocketreach_api_key

# Database
DB_PATH=./data/clients.db

# Redis (optional - for caching)
REDIS_URL=redis://localhost:6379/0

# Crawler Settings
CRAWL_INTERVAL=1800  # Run every 30 minutes
MIN_BUDGET=500       # Minimum project budget
MIN_QUALITY_SCORE=60
MAX_RESULTS=5000

# Flask
DEBUG=True
SECRET_KEY=your_secret_key_here
PORT=5000

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log

# Sentry (optional - error tracking)
SENTRY_DSN=
